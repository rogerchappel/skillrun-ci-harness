{
  "name": "skillrun-ci-harness",
  "version": "0.1.0",
  "description": "Local-first acceptance harness for agent skill fixtures.",
  "type": "module",
  "bin": {
    "skillrun-ci-harness": "./bin/skillrun-ci-harness.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check src/report.js && node --check bin/skillrun-ci-harness.js && node --check test/index.test.js",
    "smoke": "node bin/skillrun-ci-harness.js examples/skill-fixture.json --format markdown",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent",
    "skill",
    "ci",
    "harness",
    "dry-run"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skillrun-ci-harness.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skillrun-ci-harness/issues"
  },
  "homepage": "https://github.com/rogerchappel/skillrun-ci-harness#readme",
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "examples",
    "SKILL.md",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ]
}
